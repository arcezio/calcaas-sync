{
  "name": "calcaas-sync",
  "version": "0.3.0",
  "description": "Push your real AI-tool token usage to your Calcaas dashboard. A thin, privacy-preserving wrapper around ccusage.",
  "keywords": [
    "claude-code",
    "ccusage",
    "tokens",
    "usage",
    "analytics",
    "calcaas",
    "llm",
    "cost"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcezio/calcaas-sync.git"
  },
  "homepage": "https://github.com/arcezio/calcaas-sync#readme",
  "bugs": {
    "url": "https://github.com/arcezio/calcaas-sync/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "calcaas-sync": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
