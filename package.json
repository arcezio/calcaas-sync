    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ccusage": "^20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
